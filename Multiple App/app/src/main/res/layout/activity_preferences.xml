<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/aura_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Preferences"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textColor="#1B2452" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Save your favourite vibe settings."
            android:textSize="16sp"
            android:textColor="#666666"
            android:layout_marginTop="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/aura_card"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="22dp"
            android:layout_marginTop="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Favourite Vibe"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1B2452" />

            <EditText
                android:id="@+id/vibeInput"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:hint="Example: Calm Night Study"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginTop="10dp" />

            <CheckBox
                android:id="@+id/notificationCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enable notifications"
                android:textSize="17sp"
                android:textColor="#1B2452"
                android:layout_marginTop="24dp" />

            <Button
                android:id="@+id/saveBtn"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="Save Preferences"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/aura_button"
                android:layout_marginTop="30dp" />

            <Button
                android:id="@+id/backHomeBtn"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="Back Home"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#5A67FF"
                android:backgroundTint="#E9ECFF"
                android:layout_marginTop="14dp" />

            <TextView
                android:id="@+id/savedText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No preferences saved yet."
                android:textSize="17sp"
                android:textColor="#444444"
                android:layout_marginTop="24dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>