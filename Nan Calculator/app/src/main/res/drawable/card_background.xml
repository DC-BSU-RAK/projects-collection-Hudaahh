<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Soft card color -->
    <solid android:color="#F7F9FF"/>

    <!-- Soft border -->
    <stroke
        android:width="1dp"
        android:color="#DCE4FF"/>

    <!-- Rounded corners -->
    <corners android:radius="24dp"/>

    <!-- Inner spacing -->
    <padding
        android:left="14dp"
        android:top="14dp"
        android:right="14dp"
        android:bottom="14dp"/>

</shape>