<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme -->
    <style name="Base.Theme.FitFinder" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your theme here -->
    </style>

    <style name="Theme.FitFinder" parent="Base.Theme.FitFinder" />

    <!-- Section Titles -->
    <style name="SectionTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">17sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#08245C</item>
        <item name="android:layout_marginTop">16dp</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <!-- Radio Group Layout -->
    <style name="ButtonGroup">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <!-- Choice Buttons -->
    <style name="ChoiceButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textColor">#08245C</item>
        <item name="android:buttonTint">#1457D9</item>
    </style>

</resources>